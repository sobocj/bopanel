# BoPanel Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# GENERAL CONFIGURATION
# ============================================
DOMAIN=192.168.1.100
SERVER_IP=192.168.1.100
NODE_ENV=production
LOG_LEVEL=info
APP_NAME=BoPanel
APP_VERSION=1.0.0

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bopanel
DB_USER=bopanel
DB_PASSWORD=ChangeMe_DB_Password_123!
DB_DIALECT=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# REDIS CACHE CONFIGURATION
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ChangeMe_Redis_Password_456!
REDIS_DB=0

# ============================================
# JWT SECURITY
# ============================================
JWT_SECRET=ChangeMe_JWT_Secret_Key_Very_Long_And_Random_2025_XYZ123ABC!
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=ChangeMe_Refresh_Token_Secret_Very_Long_And_Random_2025_ABC456XYZ!
REFRESH_TOKEN_EXPIRE=30d

# ============================================
# ADMIN USER (Created on first run)
# ============================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@bopanel.local
ADMIN_PASSWORD=ChangeMe_Admin_Password_789!

# ============================================
# EMAIL/SMTP CONFIGURATION
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@bopanel.local
SMTP_SECURE=true
EMAIL_ENABLED=true

# ============================================
# SMS/TWILIO CONFIGURATION (Optional)
# ============================================
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# ============================================
# SLACK INTEGRATION (Optional)
# ============================================
SLACK_ENABLED=false
SLACK_WEBHOOK=
SLACK_CHANNEL=#alerts

# ============================================
# GRAFANA
# ============================================
GRAFANA_PASSWORD=ChangeMe_Grafana_Password_012!
GRAFANA_USER=admin

# ============================================
# PORTAINER
# ============================================
PORTAINER_ADMIN_PASSWORD=ChangeMe_Portainer_Password_345!

# ============================================
# URLS (Internal services)
# ============================================
API_URL=https://192.168.1.100/api
FRONTEND_URL=https://192.168.1.100
PORTAINER_URL=http://portainer:9000
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
ELASTICSEARCH_URL=http://elasticsearch:9200

# ============================================
# SECURITY
# ============================================
CORS_ORIGIN=https://192.168.1.100
SESSION_SECRET=ChangeMe_Session_Secret_Very_Long_2025!
BCRYPT_ROUNDS=10

# ============================================
# MONITORING & ALERTS
# ============================================
ALERT_EMAIL=admin@bopanel.local
ALERT_ENABLED=true
ALERT_THRESHOLD_CPU=80
ALERT_THRESHOLD_MEMORY=85
ALERT_THRESHOLD_DISK=90

# ============================================
# SLA CONFIGURATION
# ============================================
SLA_ENABLED=true
SLA_DEFAULT_RESPONSE_TIME=4
SLA_DEFAULT_RESOLUTION_TIME=24

# ============================================
# BACKUP CONFIGURATION
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups

# ============================================
# LDAP/AD CONFIGURATION (Optional)
# ============================================
LDAP_ENABLED=false
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_USER_DN=cn=admin,dc=example,dc=com
LDAP_PASSWORD=

# ============================================
# ODOO INTEGRATION (FASE 2)
# ============================================
ODOO_ENABLED=false
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USER=admin
ODOO_PASSWORD=
ODOO_SYNC_SCHEDULE=0 */2 * * *
